# NOTE: In CI, deploy/.env is generated automatically on the VPS from the GitHub
# `production` environment secrets ADMIN_PASSWORD and SESSION_SECRET (see
# .github/workflows/deploy.yml). You only need to create this file by hand for a
# local/manual deploy that doesn't go through GitHub Actions. Never commit the real .env.
#
# Password for the /admin content editor. If empty, admin login is disabled
# (public pages still render normally).
ADMIN_PASSWORD=change-this-to-a-long-random-password
#
# Secret used to sign admin session cookies. If left empty the server generates
# one and stores it on the /data volume. Set it explicitly to keep sessions
# valid across volume resets. Generate with: openssl rand -hex 32
SESSION_SECRET=
